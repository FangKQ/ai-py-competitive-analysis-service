MINIMAX_API_KEY=your_openai_api_key_here
MINIMAX_BASE_URL=https://api.openai.com/v1
MINIMAX_MODEL=gpt-5.5-2026-04-23
MODEL_LARGE=gpt-5.5-2026-04-23
MODEL_SMALL=gpt-4.1-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Multi-model cross validation
CROSS_VALIDATION_ENABLED=true

# Tavily Search API
TAVILY_API_KEY=your_tavily_api_key_here

DATABASE_URL=sqlite+aiosqlite:///./data/competitive_analysis.db
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
